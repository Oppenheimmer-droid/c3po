# ============================
# 🔐 SECURITY & APP SETTINGS
# ============================
SECRET_KEY=your_super_secret_key_here
ENVIRONMENT=development
DEBUG=true

# ============================
# 🧠 OPENAI / LLM SETTINGS
# ============================
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================
# 🗄️ DATABASE (PostgreSQL)
# ============================
POSTGRES_USER=c3po
POSTGRES_PASSWORD=c3po_secret
POSTGRES_DB=c3po_db

# SQLAlchemy / Alembic / FastAPI URL (for Docker: use service name 'postgres')
DATABASE_URL=postgresql+asyncpg://c3po:c3po_secret@postgres:5432/c3po_db
DATABASE_URL_SYNC=postgresql+psycopg2://c3po:c3po_secret@postgres:5432/c3po_db

# ============================
# 🔁 REDIS (Cache + Celery)
# ============================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================
# 🧬 CHROMADB (Local Docker)
# ============================
CHROMA_USE_CLOUD=false
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_data

# ============================
# 🌐 API HOST CONFIG
# ============================
API_HOST=0.0.0.0
API_PORT=8000
PORT=8000

# ============================
# 📡 CORS SETTINGS
# ============================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://frontend:3000
ALLOW_CREDENTIALS=true

# ============================
# 🚀 FRONTEND URLs
# ============================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
