# ============================================
# C3PO Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================
# 🔐 SECURITY & APP SETTINGS
# ============================
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ENVIRONMENT=development
DEBUG=true
PORT=8000

# ============================
# 🗄️ DATABASE (PostgreSQL)
# ============================
# Docker Compose uses these defaults
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/c3po
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/c3po

# ============================
# 🧠 AI PROVIDER SETTINGS (Groq - Primary)
# ============================
# Get your API key from: https://console.groq.com/
# FREE TIER: 30 requests per minute
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant  # Options: llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b-32768

# NOTE: If GROQ_API_KEY is not set, the system will run in DEMO MODE
# with simulated AI responses. This is useful for development and testing.

# ============================
# 🧠 OPENAI SETTINGS (Fallback)
# ============================
# Paid API - better quality but costs money
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# NOTE: If OPENAI_API_KEY is not set, the system will run in DEMO MODE

# ============================
# 🤖 AI PROVIDER SELECTION
# ============================
# Options: "groq" (recommended - faster, cheaper) or "openai"
AI_PROVIDER=groq

# ============================
# 🔁 REDIS (Cache + Celery)
# ============================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================
# 🧬 CHROMADB (Vector Store)
# ============================
CHROMA_USE_CLOUD=false
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_data

# ============================
# 📡 CORS SETTINGS
# ============================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://*.vercel.app
ALLOW_CREDENTIALS=true

# ============================
# 🌐 FRONTEND URLs
# ============================
# For local development with Docker:
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ============================================
# 🚀 DEPLOYMENT NOTES
# ============================================
#
# PRODUCTION MODE (requires API keys):
# - Set GROQ_API_KEY or OPENAI_API_KEY
# - AI responses will use real LLM models
#
# DEMO MODE (no API keys needed):
# - Leave GROQ_API_KEY and OPENAI_API_KEY empty
# - System runs with simulated AI responses
# - Perfect for development, testing, and demos
#
# Railway (Backend):
# - DATABASE_URL is auto-configured
# - Set GROQ_API_KEY in Railway environment variables
#
# Vercel (Frontend):
# - NEXT_PUBLIC_API_URL should point to Railway backend
