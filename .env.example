# ============================================
# C3PO Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================
# 🔐 SECURITY & APP SETTINGS
# ============================
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ENVIRONMENT=development
DEBUG=true
PORT=8000

# ============================
# 🗄️ DATABASE (PostgreSQL)
# ============================
# Docker Compose uses these defaults
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/c3po
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/c3po

# ============================
# 🧠 OPENAI / LLM SETTINGS
# ============================
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536
OPENAI_MOCK=true  # Set to false when you have a real API key

# ============================
# 🔁 REDIS (Cache + Celery)
# ============================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================
# 🧬 CHROMADB (Vector Store)
# ============================
CHROMA_USE_CLOUD=false
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_data

# ============================
# 📡 CORS SETTINGS
# ============================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOW_CREDENTIALS=true

# ============================
# 🌐 FRONTEND URLs
# ============================
# For local development with Docker:
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
