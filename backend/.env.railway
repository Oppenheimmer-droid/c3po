# ============================
# 🔐 SECURITY & APP SETTINGS
# ============================
SECRET_KEY=${RAILWAY_SECRET_KEY}
ENVIRONMENT=production
DEBUG=false

# ============================
# 🧠 OPENAI / LLM SETTINGS
# ============================
OPENAI_API_KEY=${OPENAI_API_KEY}

# ============================
# 🗄️ DATABASE (PostgreSQL - Railway)
# ============================
DATABASE_URL=${DATABASE_URL}

# ============================
# 🔁 REDIS (Cache + Celery - Railway)
# ============================
REDIS_URL=${REDIS_URL}
CELERY_BROKER_URL=${REDIS_URL}/1
CELERY_RESULT_BACKEND=${REDIS_URL}/2

# ============================
# 🧬 CHROMADB
# ============================
CHROMA_USE_CLOUD=true
CHROMA_CLOUD_API_KEY=${CHROMA_CLOUD_API_KEY}
CHROMA_CLOUD_HOST=api.trychroma.com
CHROMA_CLOUD_PORT=443
CHROMA_CLOUD_ENABLE_SSL=true
CHROMA_CLOUD_TENANT=default_tenant
CHROMA_CLOUD_DATABASE=default_database
CHROMA_PERSIST_DIR=/app/chroma_data

# ============================
# 🌐 API HOST CONFIG
# ============================
API_HOST=0.0.0.0
API_PORT=8000

# ============================
# 📡 CORS SETTINGS (Vercel Frontend)
# ============================
VERCEL_FRONTEND_URL=${VERCEL_FRONTEND_URL:-https://frontend-oppenheimmer-droids-projects.vercel.app}
CORS_ORIGINS=${VERCEL_FRONTEND_URL}
ALLOW_CREDENTIALS=true
