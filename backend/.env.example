# Application
APP_NAME="ReDrive Edu"
APP_VERSION="0.1.0"
DEBUG=true
API_V1_PREFIX="/api/v1"

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/redrive_edu"
DATABASE_URL_SYNC="postgresql+psycopg2://postgres:postgres@localhost:5432/redrive_edu"

# Redis
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# ChromaDB
CHROMA_PERSIST_DIR="./chroma_data"

# OpenAI (REQUIRED)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_DIM="1536"

# JWT (CHANGE IN PRODUCTION - MIN 32 CHARACTERS)
SECRET_KEY="your-super-secret-key-change-in-production-abc123"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="30"
REFRESH_TOKEN_EXPIRE_DAYS="7"

# Document Processing
MAX_FILE_SIZE_MB="50"
CHUNK_SIZE="512"
CHUNK_OVERLAP="50"

# Rate Limiting
RATE_LIMIT_PER_MINUTE="60"

# CORS
CORS_ORIGINS='["http://localhost:3000","http://localhost:8000"]'

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"