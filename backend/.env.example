# ============================
# 🔐 SECURITY & APP SETTINGS
# ============================
SECRET_KEY=your_super_secret_key_here
ENVIRONMENT=production
DEBUG=false

# ============================
# 🧠 OPENAI / LLM SETTINGS
# ============================
OPENAI_API_KEY=your_openai_api_key_here

# ============================
# 🗄️ DATABASE (PostgreSQL)
# ============================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=redrive_edu

# SQLAlchemy / Alembic / FastAPI URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/redrive_edu

# ============================
# 🔁 REDIS (Cache + Celery)
# ============================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================
# 🌐 CHROMA CLOUD / LOCAL VECTOR STORE
# ============================
CHROMA_USE_CLOUD=false
CHROMA_CLOUD_API_KEY=your_chroma_cloud_api_key_here
CHROMA_CLOUD_HOST=api.trychroma.com
CHROMA_CLOUD_PORT=443
CHROMA_CLOUD_ENABLE_SSL=true
CHROMA_CLOUD_TENANT=default_tenant
CHROMA_CLOUD_DATABASE=default_database
CHROMA_PERSIST_DIR=/chroma/chroma

# ============================
# 🌐 API HOST CONFIG
# ============================
API_HOST=0.0.0.0
API_PORT=8000
