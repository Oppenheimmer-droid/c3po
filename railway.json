{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "numReplicas": 1,
    "port": 8080,
    "healthcheck": {
      "command": ["curl", "-f", "http://localhost:8080/"],
      "interval": 30,
      "timeout": 10,
      "retries": 5,
      "startPeriod": 60
    }
  }
}
