{
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn backend.main:app --host 0.0.0.0 --port 8000",
    "healthchecks": {
      "readiness": {
        "command": "curl --fail http://0.0.0.0:8000/ready || exit 1"
      },
      "liveness": {
        "command": "curl --fail http://0.0.0.0:8000/health || exit 1"
      }
    }
  }
}
