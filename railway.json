{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "backend/Dockerfile.prod"
  },
  "deploy": {
    "numReplicas": 2,
    "sleepApplication": false,
    "restartPolicyMaxRetries": 10,
    "startCommand": "sh -c 'uvicorn app.main:app --host 0.0.0.0 --port $PORT --workers 4'",
    "environmentVariables": {
      "CORS_ORIGINS": "https://*.vercel.app,https://*.railway.app,http://localhost:3000,http://localhost:3001",
      "ENVIRONMENT": "production",
      "DEBUG": "false",
      "PYTHONDONTWRITEBYTECODE": "1",
      "PYTHONUNBUFFERED": "1"
    },
    "healthchecks": {
      "readiness": {
        "command": ["sh", "-c", "curl -f http://0.0.0.0:$PORT/health || exit 1"]
      },
      "liveness": {
        "command": ["sh", "-c", "curl -f http://0.0.0.0:$PORT/health || exit 1"]
      }
    }
  }
}