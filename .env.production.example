# ============================================
# C3PO Production Environment Variables
# ============================================
# Copy to .env.production and fill in real values
# NEVER commit .env.production to version control!

# ============================================
# DATABASE (Required)
# ============================================
POSTGRES_USER=your_prod_user
POSTGRES_PASSWORD=your_strong_prod_password
POSTGRES_DB=c3po_prod

DATABASE_URL=postgresql://your_prod_user:your_strong_prod_password@host:5432/c3po_prod
DATABASE_URL_SYNC=postgresql://your_prod_user:your_strong_prod_password@host:5432/c3po_prod

# ============================================
# SECURITY (Required - Generate strong keys!)
# ============================================
SECRET_KEY=generate-a-very-long-random-secret-key-here-min-32-chars

# ============================================
# OPENAI (Required for AI features)
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# ENVIRONMENT
# ============================================
DEBUG=false
ENVIRONMENT=production

# ============================================
# CORS (Update with your domains)
# ============================================
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# CHROMADB
# ============================================
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ============================================
# URLs (Update with your deployment URLs)
# ============================================
BACKEND_URL=https://api.yourdomain.com
BACKEND_WS_URL=wss://api.yourdomain.com

# ============================================
# OPTIONAL: SMTP for emails
# ============================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM=noreply@yourdomain.com
